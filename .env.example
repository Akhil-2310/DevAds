# ── Paymaster wallet (DEMO ONLY) ───────────────────────────────────────────
# The autonomous agent signs x402 payments with this key. Fund this address
# with Monad testnet USDC (token 0x534b2f3A21130d7a60830c2Df862319e593943A3).
# Facilitator pays gas, so it only needs USDC — not MON.
PRIVATE_KEY=0xYOUR_FUNDED_TESTNET_PRIVATE_KEY

# ── Anthropic ──────────────────────────────────────────────────────────────
# Used by both the coding CLI and the paymaster agent.
ANTHROPIC_API_KEY=sk-ant-...

# ── Wiring ─────────────────────────────────────────────────────────────────
COORDINATOR_URL=http://localhost:3000
# Reward paid per watched ad, as a dollar string (x402 price format)
DEFAULT_REWARD=$0.01

# ── Smoke test ─────────────────────────────────────────────────────────────
# Where the $0.001 smoke payment lands. Set to a second address you can watch
# (or the same wallet — self-pay still proves the round-trip settles).
PAY_TO_ADDRESS=0xRECEIVER_ADDRESS
