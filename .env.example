# ─────────────────────────────────────────────────────────────────────────
# DevAds — environment template
# Copy this file:   cp .env.example .env
# The coordinator (Next.js) reads apps/coordinator/.env.local, so also copy
# the coordinator-side vars there. The CLI only needs COORDINATOR_URL.
# ─────────────────────────────────────────────────────────────────────────

# ── Coordinator URL ────────────────────────────────────────────────────────
# Where the CLI and paymaster send requests (ads, claims, the Anthropic proxy).
#   Local dev:   http://localhost:3000
#   Production:  https://devads-coordinator.vercel.app   (or your own Vercel URL)
COORDINATOR_URL=http://localhost:3000

# ── Supabase  (coordinator only) ────────────────────────────────────────────
# Dashboard → Project Settings → API. Run `supabase db push` to apply the
# migrations in ./supabase/migrations, and create a Storage bucket named "ads".
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...   # server-only

# ── Anthropic  (coordinator only) ───────────────────────────────────────────
# The gateway proxy holds this key and meters usage by ad-credits.
# End users of the CLI never need their own key.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Monad testnet x402 payouts  (coordinator + paymaster) ───────────────────
# PRIVATE_KEY funds the on-chain USDC payouts to viewers — must hold Monad
# testnet USDC. PAY_TO_ADDRESS is only used by the /api/smoke test route.
PRIVATE_KEY=0xYOUR_FUNDED_MONAD_TESTNET_WALLET_PRIVATE_KEY
PAY_TO_ADDRESS=0xYOUR_TEST_RECIPIENT_ADDRESS
DEFAULT_REWARD=$0.02

# Protocol wallet advertisers deposit their campaign budget into. For payouts to
# be funded by advertiser deposits, this should be the SAME wallet as PRIVATE_KEY
# above (i.e. set PRIVATE_KEY to this address's key) — see README/run notes.
ADDRESS_OF_PROTOCOL=0xYOUR_PROTOCOL_WALLET_ADDRESS

# ── Credits ─────────────────────────────────────────────────────────────────
# Agent turns granted to a viewer per ad watched.
CREDITS_PER_VIEW=10

# ── Paymaster  (Azure daemon) ───────────────────────────────────────────────
# How often the settlement loop polls for pending claims, in milliseconds.
PAYMASTER_POLL_MS=5000
